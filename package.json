{
  "name": "pi-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A lightweight local-first web chat for Pi",
  "bin": {
    "pi-chat": "dist/server/server/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "start-pi-chat.cmd"
  ],
  "scripts": {
    "prepare:katex": "node scripts/prepare-katex-css.mjs",
    "dev": "npm run prepare:katex && tsx watch src/server/index.ts --dev",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm run prepare:katex && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^26.1.0",
    "katex": "^0.16.22",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
